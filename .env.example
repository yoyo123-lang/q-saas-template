# =============================================================================
# Q SaaS Template — Variables de entorno
# =============================================================================
# Copiá este archivo como .env.local y completá los valores.
# Nunca commitees .env.local ni archivos con secretos reales.
# =============================================================================

# --- Base de datos (Supabase PostgreSQL) ---
# Connection pooling URL (para la app)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true"
# Conexión directa (para migraciones de Prisma)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ===== AUTH =====
AUTH_SECRET=""                    # openssl rand -base64 32
ADMIN_EMAIL=""                    # Email del admin (auto-promote a ADMIN)
NEXT_PUBLIC_APP_URL="http://localhost:3000"  # URL pública de la app
NEXT_PUBLIC_APP_NAME=""           # Nombre visible de la app (ej: "Mi SaaS")

# ===== OAUTH =====
GOOGLE_CLIENT_ID=""               # Google Cloud Console → Credentials
GOOGLE_CLIENT_SECRET=""

# ===== EMAIL (Resend) =====
RESEND_API_KEY=""                 # https://resend.com/api-keys
EMAIL_FROM=""                     # "App Name <noreply@domain.com>"

# ===== CROSS-BU SYNC =====
BU_SLUG=""                        # Slug de esta BU en el ecosistema Q (ej: "qontabiliza")
BOARD_URL="https://q-company.vercel.app"  # URL de Q-Company Board
BOARD_API_KEY=""                  # API key de esta BU en Q-Company
BOARD_BU_ID=""                    # ID de esta BU en Q-Company
BOARD_WEBHOOK_SECRET=""           # Secret para validar webhooks entrantes

# ===== CRON =====
# Secret para proteger endpoints de cron (Vercel Cron lo envía automáticamente).
# Generar con: openssl rand -base64 32
CRON_SECRET=""

# --- NextAuth (legacy — usar AUTH_SECRET arriba para NextAuth v5) ---
# NEXTAUTH_URL="http://localhost:3000"  # Solo necesario en dev si AUTH_URL no está seteado

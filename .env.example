# =============================================================================
# Q SaaS Template — Variables de entorno
# =============================================================================
# Copiá este archivo como .env.local y completá los valores.
# Nunca commitees .env.local ni archivos con secretos reales.
# =============================================================================

# --- Base de datos (Supabase PostgreSQL) ---
# Connection pooling URL (para la app)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true"
# Conexión directa (para migraciones de Prisma)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# --- URL pública de la app ---
# Usada para SEO, Open Graph y sitemap. Reemplaza a NEXTAUTH_URL en esos contextos.
# En Vercel se setea automáticamente como VERCEL_URL (sin https://), pero es mejor definirla explícita.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- NextAuth ---
# URL base de la app para el flujo de auth. En producción Vercel lo detecta automáticamente.
NEXTAUTH_URL="http://localhost:3000"
# Secret para firmar sesiones — generar con: openssl rand -base64 32
NEXTAUTH_SECRET=""

# --- Google OAuth ---
# Obtener en Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Redirect URI: http://localhost:3000/api/auth/callback/google (dev)
#               https://tu-dominio.com/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Admin ---
# Email del admin: usado en seed (tabla AllowedEmail) y en runtime (auto-promoción a ADMIN en primer login)
ADMIN_EMAIL=""
